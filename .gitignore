minecraft/bluemap/
minecraft/showdown/
minecraft/Distant_Horizons_server_data/

# --- 大容量キャッシュ (100MB超の元・配布不要) ---
minecraft/armourers_workshop/skin-cache/
minecraft/armourers_workshop/skin-database/

# --- 管理者の作業バックアップ (配布不要) ---
*.bak
*.backup0

# --- OS/ツール ---
Thumbs.db
desktop.ini
.DS_Store
